"VertexLitGeneric"
{
	"$basetexture"	"models/weapons/c_items/c_coconut"

	"$phong" "1"
	"$phongexponent" "28"
	"$phongboost" ".2"	

	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"
	"$phongfresnelranges"	"[.3 .5 3]"
	"$basemapalphaphongmask" "1"
	//"$normalmapalphaenvmapmask" "1"
	
	"$rimlight" "1"
	"$rimlightexponent" "20"				
	"$rimlightboost" "2"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"weapon_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
