"VertexLitGeneric"
{
	"$baseTexture" "models\weapons\w_bible/bible"
 
	"$phongdisablehalflambert" "1"
	"$phong"	"1"
	"$phongexponent" "10"
	"$phongboost" ".2"	
	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"
	"$phongfresnelranges"	"[.25 .5 1]"
	"$basemapalphaphongmask" "1"

	"$rimlight" "1"
	"$rimlightexponent" "4"	
	"$rimlightboost" "2"

	"360?$color2" "[ 0.9 0.8 0.8 ]"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"

	"$yellow" "0"

    "Proxies"
    {
        "ConVarEx"
        {
             "ConVar" "tf2c_player_nohalflambert"
              "0"
                {
                     "$PhongDisableHalfLambert"  "0"
                }
               "1"
               {
                   "$PhongDisableHalfLambert"  "1"
               }
        }
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}
